# Application
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/mizumba

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_CONFIRMATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
MAX_AUDIO_UPLOAD_SIZE_MB=25

# Whisper
ENABLE_WHISPER_TRANSCRIPTION=false
WHISPER_MODEL_NAME=base
WHISPER_DEFAULT_LANGUAGE=

# OAuth
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@mizumba.app
SMTP_USE_TLS=true

# Storage
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate Limiting
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Other
DEFAULT_COUNTRY_CODE=DEFAULT
AUTH_PROVIDER_RULES_JSON={"DEFAULT":{"google":true,"apple":true},"RU":{"google":false,"apple":false}}